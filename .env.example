# Vapi (https://dashboard.vapi.ai) — create an account, then:
#   - copy your private API key from Dashboard -> API Keys
#   - create/buy a phone number under Dashboard -> Phone Numbers and copy its ID
VAPI_API_KEY=your-vapi-private-api-key
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id

# OpenAI — used for the offline transcript bug-analysis pass (and, optionally,
# as the in-call brain via a Vapi provider credential).
OPENAI_API_KEY=sk-your-openai-key

# The Pretty Good AI test agent. Do NOT change this — all test calls go here.
TARGET_NUMBER=+18054398008

# Optional tuning
OPENAI_MODEL=gpt-4o
ANALYZER_MODEL=gpt-4o
MAX_CALL_SECONDS=180
